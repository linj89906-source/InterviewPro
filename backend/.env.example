# ============================================
# InterviewPro 环境变量配置
# 复制此文件为 .env 并填入真实值（本地开发用）
# 部署到 Render 时在 Dashboard 中设置这些变量
# ============================================

# ---------- AI 模型配置 ----------
# DeepSeek API（兼容 OpenAI 接口）
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 也可使用 OpenAI 官方：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---------- 地图服务 ----------
# 高德地图 API Key（用于面试地点搜索和住宿推荐）
AMAP_API_KEY=your-amap-api-key-here

# ---------- 数据库 ----------
# 本地开发使用 SQLite（默认），无需修改
# Render 部署时也使用 SQLite（免费，但重启后数据丢失）
# 如需持久化，可改为 PostgreSQL 连接串
DATABASE_URL=sqlite:///./interview.db

# ---------- CORS（仅生产环境需要） ----------
# 部署到 Render 后，设置为前端域名，多个用逗号分隔
# 例如：ALLOWED_ORIGINS=https://your-app.vercel.app
# 本地开发不需要设置（默认允许所有来源）
# ALLOWED_ORIGINS=
